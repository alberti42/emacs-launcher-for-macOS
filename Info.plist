<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Info.plist for "Emacs Launcher.app".

  Static template copied verbatim by emacs-launcher-build.sh. It declares:
    * the org-protocol:// URL scheme               (CFBundleURLTypes)
    * Emacs-specific imported UTIs for .org/.el/.eld/.texi  (UTImportedTypeDeclarations)
    * document types: the custom UTIs, a broad text/source catch-all, and Markdown
                                                    (CFBundleDocumentTypes)
    * LSUIElement so the launcher is invisible in the Dock.

  Role is "Editor" everywhere so the app appears in Finder's "Open With" — but we do
  NOT force any default handler (no LSSetDefaultRoleHandler at install). The user opts
  in per-type via Finder. Custom UTIs are *imported* (we conform to / re-declare types
  that Emacs owns but the system may not know), kept alongside the broad UTIs so plain
  text and source files are still covered even when an extension has no named type.
-->
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>Emacs Launcher</string>
    <key>CFBundleDisplayName</key>
    <string>Emacs Launcher</string>
    <key>CFBundleIdentifier</key>
    <string>io.alberti42.EmacsLauncher</string>
    <key>CFBundleExecutable</key>
    <string>EmacsLauncher</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>12.0</string>
    <key>NSHighResolutionCapable</key>
    <true/>

    <!-- Invisible launcher: no Dock icon, no menu bar; still receives open events. -->
    <key>LSUIElement</key>
    <true/>

    <!-- Icon: Tahoe (macOS 26+) reads from Assets.car; CFBundleIconName names the
         icon group inside it. CFBundleIconFile is the pre-Tahoe .icns fallback. -->
    <key>CFBundleIconName</key>
    <string>dragon</string>
    <key>CFBundleIconFile</key>
    <string>applet</string>

    <key>CFBundleURLTypes</key>
    <array>
        <!-- emacs://file/<percent-encoded-path>[+LINE[:COLUMN]] — open a file at a
             position. Parsed by the app itself (no Emacs config needed). The scheme
             string ("emacs") must match `openFileScheme` in main.swift. -->
        <dict>
            <key>CFBundleURLName</key>
            <string>Open File in Emacs</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>emacs</string>
            </array>
        </dict>
        <!-- org-protocol:// (org-capture, org-roam, etc.) — forwarded verbatim to the
             daemon, where Org's org-protocol library interprets it. -->
        <dict>
            <key>CFBundleURLName</key>
            <string>Org Protocol</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>org-protocol</string>
            </array>
        </dict>
    </array>

    <!-- Emacs-specific types the system may not know by extension. -->
    <key>UTImportedTypeDeclarations</key>
    <array>
        <dict>
            <key>UTTypeIdentifier</key>
            <string>org.gnu.emacs.org-mode</string>
            <key>UTTypeDescription</key>
            <string>Org Mode Document</string>
            <key>UTTypeConformsTo</key>
            <array>
                <string>public.plain-text</string>
            </array>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array>
                    <string>org</string>
                    <string>org_archive</string>
                </array>
            </dict>
        </dict>
        <dict>
            <key>UTTypeIdentifier</key>
            <string>org.gnu.emacs.emacs-lisp-source</string>
            <key>UTTypeDescription</key>
            <string>Emacs Lisp Source</string>
            <key>UTTypeConformsTo</key>
            <array>
                <string>public.source-code</string>
                <string>public.plain-text</string>
            </array>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array>
                    <string>el</string>
                </array>
            </dict>
        </dict>
        <dict>
            <key>UTTypeIdentifier</key>
            <string>org.gnu.emacs.lisp-data</string>
            <key>UTTypeDescription</key>
            <string>Emacs Lisp Data</string>
            <key>UTTypeConformsTo</key>
            <array>
                <string>public.plain-text</string>
            </array>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array>
                    <string>eld</string>
                </array>
            </dict>
        </dict>
        <dict>
            <key>UTTypeIdentifier</key>
            <string>org.gnu.emacs.texinfo-source</string>
            <key>UTTypeDescription</key>
            <string>Texinfo Document</string>
            <key>UTTypeConformsTo</key>
            <array>
                <string>public.source-code</string>
                <string>public.plain-text</string>
            </array>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array>
                    <string>texi</string>
                    <string>texinfo</string>
                </array>
            </dict>
        </dict>
    </array>

    <key>CFBundleDocumentTypes</key>
    <array>
        <!-- Emacs-specific named types (from UTImportedTypeDeclarations above). -->
        <dict>
            <key>CFBundleTypeName</key>
            <string>Emacs Document</string>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>org.gnu.emacs.org-mode</string>
                <string>org.gnu.emacs.emacs-lisp-source</string>
                <string>org.gnu.emacs.lisp-data</string>
                <string>org.gnu.emacs.texinfo-source</string>
            </array>
        </dict>
        <!-- Markdown. -->
        <dict>
            <key>CFBundleTypeName</key>
            <string>Markdown Document</string>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>net.daringfireball.markdown</string>
                <string>public.markdown</string>
            </array>
        </dict>
        <!-- Broad catch-all so any plain text / source / script file is covered. -->
        <dict>
            <key>CFBundleTypeName</key>
            <string>Text Document</string>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>public.text</string>
                <string>public.plain-text</string>
                <string>public.source-code</string>
                <string>public.script</string>
                <string>public.shell-script</string>
                <string>public.xml</string>
                <string>public.json</string>
                <string>public.data</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
